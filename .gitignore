# =============================================================================
# React Native Plugin — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Node / JavaScript
# -----------------------------------------------------------------------------
node_modules/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.yarn-integrity

# -----------------------------------------------------------------------------
# Plugin build output (generated by tsc / bob)
# -----------------------------------------------------------------------------
lib/
build/
dist/

# -----------------------------------------------------------------------------
# iOS — root plugin
# -----------------------------------------------------------------------------
# (no Pods at root; CocoaPods is only used inside example/)

# -----------------------------------------------------------------------------
# iOS — example app
# -----------------------------------------------------------------------------
example/ios/Pods/
example/ios/build/
example/ios/DerivedData/

# Xcode user-specific files
xcuserdata/
*.xcuserstate
*.xccheckout
*.moved-aside
DerivedData/
*.hmap
*.ipa

# Xcode per-user settings (committed defaults are kept)
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3

# Local Xcode environment overrides
**/.xcode.env.local

# CocoaPods lock is committed in the example app to pin dependency versions.
# Uncomment the line below only if you intentionally do NOT want to pin them.
# example/ios/Podfile.lock

# -----------------------------------------------------------------------------
# Android — example app
# -----------------------------------------------------------------------------
example/android/build/
example/android/app/build/
example/android/.gradle/
example/android/local.properties
example/android/.cxx/
example/android/app/.cxx/

# Android Studio / IntelliJ
.idea/
*.iml
.project
.classpath
.settings/

# Gradle caches
.gradle/
local.properties

# Android memory profiler snapshots
*.hprof

# -----------------------------------------------------------------------------
# Ruby / CocoaPods (Bundler)
# -----------------------------------------------------------------------------
example/vendor/
vendor/bundle/

# Gemfile.lock is committed inside example/ to pin Ruby gem versions.
# Uncomment if you want to ignore it:
# example/Gemfile.lock

# -----------------------------------------------------------------------------
# Codegen — generated at build time, must not be committed
# -----------------------------------------------------------------------------
example/ios/build/generated/

# -----------------------------------------------------------------------------
# Metro
# -----------------------------------------------------------------------------
.metro-health-check*

# -----------------------------------------------------------------------------
# macOS
# -----------------------------------------------------------------------------
.DS_Store
**/.DS_Store

# -----------------------------------------------------------------------------
# Windows
# -----------------------------------------------------------------------------
Thumbs.db
*.stackdump

# -----------------------------------------------------------------------------
# Editor / IDE
# -----------------------------------------------------------------------------
.vscode/
.vs/
*.swp
*.swo
.idea/

# -----------------------------------------------------------------------------
# Environment / secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
